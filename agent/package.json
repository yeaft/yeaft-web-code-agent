{
  "name": "@yeaft/webchat-agent",
  "version": "1.0.0",
  "description": "Remote agent for Yeaft WebChat — connects worker machines to the central server",
  "main": "index.js",
  "type": "module",
  "bin": {
    "yeaft-agent": "./cli.js",
    "yeaft": "./yeaft/cli.js",
    "yeaft-stats": "./bin/yeaft-stats.js"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "keywords": [
    "claude",
    "agent",
    "remote",
    "websocket",
    "cli",
    "yeaft"
  ],
  "homepage": "https://github.com/yeaft/claude-web-chat",
  "repository": {
    "type": "git",
    "url": "https://github.com/yeaft/claude-web-chat.git",
    "directory": "agent"
  },
  "bugs": {
    "url": "https://github.com/yeaft/claude-web-chat/issues"
  },
  "files": [
    "**/*.js",
    "yeaft/templates/**/*.md",
    "yeaft/dream/prompts/**/*.md"
  ],
  "license": "MIT",
  "author": "Yeaft",
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "nodemonConfig": {
    "watch": ["*.js", "sdk/*.js"],
    "ignore": ["node_modules", "package-lock.json", ".claude-agent.json"],
    "ext": "js"
  },
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "dotenv": "^16.3.1",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^11.1.0",
    "ws": "^8.16.0"
  }
}
